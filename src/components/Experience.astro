---
import ExperienceItem from "./ExperienceItem.astro";

const EXPERIENCE = [
  {
    date: "September 2025 - Present",
    title: "Sales Representative – Digi",
    description: [
      "Advised and sold telecommunications services (fibre, mobile and rate plans) to private customers.",
      "Acquired new customers and managed the existing client portfolio.",
      "Identified customer needs to offer the best solution and close sales.",
      "Met commercial targets while providing direct, personalized customer service.",
    ],
  },
  {
    date: "March 2024 - November 2024",
    title: "Internship Agreement - Escola Tabor",
    description: [
      "Maintained and updated the school’s website using WordPress.",
      "Developed a new school website from scratch using Wix.",
      "Designed and launched a new Moodle platform for parent-teacher-student communication.",
      "Used technologies including WordPress, Moodle, PHP, HTML, CSS, JavaScript, and MySQL.",
      "Managed hosting and domain setup with IONOS, using cPanel and FTP tools like FileZilla.",
    ],
    link: "https://www.tabor.cat/",
  },
  {
    date: "June 2024 - December 2024",
    title: "Sales and IT Advisor – Plaza Cataluña",
    description: [
      "Provided personalized customer service and technical advice on technology products.",
      "Troubleshot basic technical issues and offered user support.",
      "Managed cash register, inventory, and organized store operations.",
      "Developed strong communication, problem-solving, and sales skills.",
    ],
  },
];
---

<ol class="border-white/30 dark:border-gray-700 pl-2 pt-3 mt-10">
  {
    EXPERIENCE.map((experience) => (
      <li class="mb-10 relative">
        <ExperienceItem {...experience} />
      </li>
    ))
  }
</ol>
