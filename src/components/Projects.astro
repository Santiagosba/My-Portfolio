<style>
  .project-card {
    @apply p-6;
  }
  .project-img {
    @apply rounded-2xl w-full object-cover shadow-lg;
    height: 180px;
    border: 1px solid rgba(255,255,255,0.15);
  }
  .project-title {
    @apply mt-4 text-xl font-bold text-white;
    text-shadow: 0 2px 8px rgba(173,216,230,0.4);
  }
  .project-desc {
    @apply mt-2 text-white/80 text-sm leading-relaxed;
  }
  .project-tags {
    @apply flex gap-3 mt-4;
  }
  .project-links {
    @apply flex gap-3 mt-5;
  }
  .btn {
    @apply px-4 py-1.5 rounded-full text-sm font-medium text-white/90;
    background: linear-gradient(155deg, rgba(255,255,255,0.12) 0%, rgba(200,215,255,0.04) 50%, rgba(255,255,255,0.01) 100%);
    backdrop-filter: blur(32px) saturate(240%) brightness(1.14);
    -webkit-backdrop-filter: blur(32px) saturate(240%) brightness(1.14);
    border-top:    1.5px solid rgba(255,255,255,0.65);
    border-left:   1px   solid rgba(255,255,255,0.22);
    border-right:  1px   solid rgba(255,255,255,0.08);
    border-bottom: 1px   solid rgba(255,255,255,0.06);
    box-shadow:
      inset 0 1.5px 0 rgba(255,255,255,0.80),
      inset 1.5px 0 0 rgba(255,255,255,0.20),
      inset -1px 0 0 rgba(0,0,0,0.18),
      inset 0 -1.5px 0 rgba(0,0,0,0.25),
      0 8px 24px rgba(0,0,0,0.40),
      0 2px 6px rgba(0,0,0,0.22);
    transition: transform 0.28s cubic-bezier(0.34,1.56,0.64,1), box-shadow 0.28s ease;
  }
  .btn:hover {
    transform: translateY(-2px) scale(1.04);
    box-shadow:
      inset 0 1.5px 0 rgba(255,255,255,0.95),
      inset 1.5px 0 0 rgba(255,255,255,0.26),
      inset -1px 0 0 rgba(0,0,0,0.18),
      inset 0 -1.5px 0 rgba(0,0,0,0.25),
      0 12px 36px rgba(0,0,0,0.48),
      0 0 20px rgba(110,70,220,0.22);
  }
</style>
