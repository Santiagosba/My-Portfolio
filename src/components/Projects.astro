---
import ReactIcon from "./icons/ReactIcon.astro";
import HtmlIcon from "./icons/HTMLIcon.astro";
import CSSIcon from "./icons/CSSIcon.astro";
import JavascriptIcon from "./icons/JavascriptIcon.astro";
import ViteIcon from "./icons/ViteIcon.astro";
import TailwindIcon from "./icons/TAILWINDCSSicon.astro";
import TypeScriptIcon from "./icons/TypescriptIcon.astro";
import ThreeJSIcon from "./icons/ThreeJSIcon.astro";
import NodeIcon from "./icons/NodeIcon.astro";
import PrismaIcon from "./icons/PrismaIcon.astro";
import PostgreSQLIcon from "./icons/PostgreSQLIcon.astro";
---

<div class="grid gap-10 md:grid-cols-2 lg:grid-cols-3 max-w-6xl mx-auto">
  <!-- Proyecto -->
  <article class="project-card lg-card">
    <img src="/projects/coachos.webp" alt="CoachOS" class="project-img" loading="lazy" />
    <h3 class="project-title">CoachOS</h3>
    <p class="project-desc">A platform for personal trainers and their clients. Trainers manage clients, training programs and a session calendar, while clients follow their daily workout, log sets, reps, weight and RPE, and track their training history. Built with React Native (Expo) and a Node + Express + TypeScript API with Prisma and PostgreSQL.</p>
    <div class="project-tags">
      <ReactIcon class="w-7 h-7" />
      <TypeScriptIcon class="w-7 h-7" />
      <NodeIcon class="w-7 h-7" />
      <PrismaIcon class="w-7 h-7" />
      <PostgreSQLIcon class="w-7 h-7" />
    </div>
    <div class="project-links">
      <a href="https://github.com/Santiagosba/CoachOS" target="_blank" class="btn">View Code</a>
    </div>
  </article>

  <!-- Proyecto -->
  <article class="project-card lg-card">
    <img src="/projects/bmth_media_player.webp" alt="Music Player" class="project-img" loading="lazy" />
    <h3 class="project-title">BMTH Music Player</h3>
    <p class="project-desc">A custom music player to listen to Bring Me The Horizon.</p>
    <div class="project-tags">
      <ReactIcon class="w-7 h-7" />
      <TypeScriptIcon class="w-7 h-7" />
      <ViteIcon class="w-7 h-7" />
      <TailwindIcon class="w-7 h-7" />
    </div>
    <div class="project-links">
      <a href="https://github.com/Santiagosba/Bmth-Media-Player" target="_blank" class="btn">View Code</a>
      <a href="https://bmthmediaplayer.netlify.app/" target="_blank" class="btn">View Project</a>
    </div>
  </article>

  <!-- Proyecto -->
  <article class="project-card lg-card">
    <img src="/projects/RubikCube.webp" alt="Rubik Cube 3D" class="project-img" loading="lazy" />
    <h3 class="project-title">Rubik Cube 3D</h3>
    <p class="project-desc">A 3D interactive Rubik’s Cube built with React and Three.js.</p>
    <div class="project-tags">
      <ReactIcon class="w-7 h-7" />
      <ViteIcon class="w-7 h-7" />
      <ThreeJSIcon class="w-7 h-7" />
    </div>
    <div class="project-links">
      <a href="https://github.com/Santiagosba/Rubik-Cube" target="_blank" class="btn">View Code</a>
      <a href="https://rubikcube3d.netlify.app/" target="_blank" class="btn">View Project</a>
    </div>
  </article>

  <!-- Proyecto -->
  <article class="project-card lg-card">
    <img src="/projects/Digital World Clock.webp" alt="World Clock" class="project-img" loading="lazy" />
    <h3 class="project-title">World Clock</h3>
    <p class="project-desc">An interactive world clock with military aesthetic and timezones.</p>
    <div class="project-tags">
      <HtmlIcon class="w-7 h-7" />
      <CSSIcon class="w-7 h-7" />
      <JavascriptIcon class="w-7 h-7" />
    </div>
    <div class="project-links">
      <a href="https://github.com/Santiagosba/Digital-World-Clock" target="_blank" class="btn">View Code</a>
      <a href="https://militarclock.netlify.app/" target="_blank" class="btn">View Project</a>
    </div>
  </article>

