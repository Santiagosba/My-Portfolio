<style>
  .project-card {
    @apply p-6;
  }
  .project-img {
    @apply rounded-2xl w-full object-cover shadow-lg;
    height: 180px;
    border: 1px solid rgba(255,255,255,0.15);
  }
  .project-title {
    @apply mt-4 text-xl font-bold text-white;
    text-shadow: 0 2px 8px rgba(173,216,230,0.4);
  }
  .project-desc {
    @apply mt-2 text-white/80 text-sm leading-relaxed;
  }
  .project-tags {
    @apply flex gap-3 mt-4;
  }
  .project-links {
    @apply flex gap-3 mt-5;
  }
  .btn {
    @apply px-4 py-1.5 rounded-full text-sm font-medium text-white/90;
    background-image:
      linear-gradient(180deg, rgba(255,255,255,0.05) 0%, rgba(255,255,255,0.01) 45%, rgba(0,0,0,0.10) 100%),
      linear-gradient(108deg, transparent 0%, rgba(255,255,255,0.055) 45%, transparent 65%);
    backdrop-filter: blur(7px) saturate(150%) contrast(1.03) brightness(1.04);
    -webkit-backdrop-filter: blur(7px) saturate(150%) contrast(1.03) brightness(1.04);
    border: 1px solid rgba(255,255,255,0.12);
    border-top-color: rgba(255,255,255,0.38);
    box-shadow:
      inset 0 1px 0 rgba(255,255,255,0.24),
      /* Chromatic aberration — red one side, cyan the other */
      -1px 0 0 rgba(255,40,90,0.15),
       1px 0 0 rgba(40,200,255,0.17),
      inset 2px 0 8px -2px rgba(255,40,90,0.44),
      inset -2px 0 8px -2px rgba(40,200,255,0.48),
      inset 0 -1px 0 rgba(0,0,0,0.48),
      0 8px 24px rgba(0,0,0,0.38),
      0 2px 6px rgba(0,0,0,0.22);
    transition: transform 0.28s cubic-bezier(0.34,1.56,0.64,1), box-shadow 0.28s ease, border-color 0.28s ease;
  }
  .btn:hover {
    transform: translateY(-2px) scale(1.04);
    border-top-color: rgba(255,255,255,0.52);
    box-shadow:
      inset 0 1px 0 rgba(255,255,255,0.32),
      -1.5px 0 0 rgba(255,40,90,0.24),
       1.5px 0 0 rgba(40,200,255,0.28),
      inset 2px 0 10px -2px rgba(255,40,90,0.58),
      inset -2px 0 10px -2px rgba(40,200,255,0.62),
      inset 0 -1px 0 rgba(0,0,0,0.48),
      0 12px 36px rgba(0,0,0,0.46),
      0 0 20px rgba(110,70,220,0.20);
  }
</style>
