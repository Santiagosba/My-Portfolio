    <p class="project-desc">A management platform for coaches to organize clients, plans and training sessions.</p>
    <div class="project-tags">
      <ReactIcon class="w-7 h-7" />
      <TypeScriptIcon class="w-7 h-7" />
      <ViteIcon class="w-7 h-7" />
      <TailwindIcon class="w-7 h-7" />
    </div>
    <div class="project-links">
      <a href="https://github.com/Santiagosba/CoachOS" target="_blank" class="btn">View Code</a>
    </div>
  </article>

  <!-- Proyecto -->
  <article class="project-card lg-card">
