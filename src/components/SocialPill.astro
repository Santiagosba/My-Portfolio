---
const { href, label } = Astro.props;
const hasLabel = Boolean(label);
---

<a
  href={href}
  target="_blank"
  rel="noopener noreferrer"
  aria-label={label}
  class={`group lg-pill inline-flex items-center
    ${hasLabel ? "gap-2 px-5 py-2" : "w-12 h-10 justify-center"}
    rounded-full text-white/90`}
>
  <slot />
  {hasLabel && (
    <span class="text-xs font-medium group-hover:text-violet-200 transition">
      {label}
    </span>
  )}
</a>
