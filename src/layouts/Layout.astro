---
import "../styles/global.css";
import Header from "../components/Header.astro";
import "@fontsource-variable/onest";
import Footer from "../components/Footer.astro";
interface Props {
  title: string;
  description: string;
}
const { description, title } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta http-equiv="X-UA-Compatible" content="ie=edge" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={description} />

    <meta
      name="description"
      content="Santiago's personal portfolio showcasing his work and skills."
    />
    <title>Santiago Portfolio</title>
  </head>
  <body class="relative bg-black text-white min-h-screen flex flex-col overflow-x-hidden w-full">
    
    <!-- Space canvas (stars + nebulae + shooting stars) -->
    <div class="fixed inset-0 -z-10 pointer-events-none">
      <canvas id="star-canvas" class="w-full h-full"></canvas>
    </div>

    <!-- Layout principal -->
    <Header class="relative z-10 bg-transparent" />

   <main class="relative flex-grow z-0 mt-20 px-4">
  <div class="max-w-7xl w-full mx-auto">
    <slot />
  </div>
  <Footer />
</main>


    <script is:inline>
    (function () {
      const canvas = document.getElementById('star-canvas');
      const ctx    = canvas.getContext('2d');
      let W = 0, H = 0, stars = [], shooters = [], nebula = null, t = 0;

      /* ── Resize ── */
      function resize() {
        W = canvas.width  = window.innerWidth;
        H = canvas.height = window.innerHeight;
        nebula = null;
        buildStars();
      }
      window.addEventListener('resize', resize);
      resize();

      /* ── Nebula (painted once to an offscreen canvas) ── */
      function buildNebula() {
        const nc = document.createElement('canvas');
        nc.width = W; nc.height = H;
        const nx = nc.getContext('2d');

        // Deep-space base gradient
        const base = nx.createRadialGradient(W*0.5, H*0.3, 0, W*0.5, H*0.3, W*0.9);
        base.addColorStop(0,   'rgba(10,8,30,0.95)');
        base.addColorStop(1,   'rgba(0,0,8,1)');
        nx.fillStyle = base;
        nx.fillRect(0, 0, W, H);

        // Nebula clouds
        const clouds = [
          { cx:0.22, cy:0.20, r:0.48, stops:[[0,'rgba(100,45,200,0.24)'],[0.4,'rgba(65,25,140,0.11)'],[1,'rgba(0,0,0,0)']] },
          { cx:0.76, cy:0.62, r:0.42, stops:[[0,'rgba(20,60,190,0.20)'],[0.5,'rgba(12,38,115,0.09)'],[1,'rgba(0,0,0,0)']] },
          { cx:0.50, cy:0.88, r:0.34, stops:[[0,'rgba(10,85,145,0.16)'],[1,'rgba(0,0,0,0)']] },
          { cx:0.88, cy:0.14, r:0.26, stops:[[0,'rgba(85,22,160,0.18)'],[1,'rgba(0,0,0,0)']] },
          { cx:0.36, cy:0.50, r:0.20, stops:[[0,'rgba(40,70,210,0.10)'],[1,'rgba(0,0,0,0)']] },
        ];
        clouds.forEach(c => {
          const g = nx.createRadialGradient(c.cx*W, c.cy*H, 2, c.cx*W, c.cy*H, c.r*W);
          c.stops.forEach(([s, col]) => g.addColorStop(s, col));
          nx.fillStyle = g;
          nx.fillRect(0, 0, W, H);
        });
        return nc;
      }

      /* ── Stars (3 layers) ── */
      function buildStars() {
        stars = [];
        // Micro dust — many, tiny, dim
        for (let i = 0; i < 320; i++)
          stars.push(mkStar(Math.random()*0.3+0.15, Math.random()*0.5+0.2, 0.012, false));
        // Regular stars
        for (let i = 0; i < 140; i++)
          stars.push(mkStar(Math.random()*0.4+0.38, Math.random()*0.65+0.65, 0.020, false));
        // Bright stars with bloom
        for (let i = 0; i < 22; i++)
          stars.push(mkStar(Math.random()*0.28+0.70, Math.random()*1.1+1.5, 0.032, true));
      }

      function mkStar(base, r, freq, glow) {
        return { x:Math.random()*W, y:Math.random()*H, r, base,
                 range: 0.14, phase:Math.random()*Math.PI*2, freq, glow };
      }

      /* ── Main loop ── */
      function frame() {
        t += 0.016;

        // Background fill
        ctx.fillStyle = '#00000c';
        ctx.fillRect(0, 0, W, H);

        // Nebula
        if (!nebula) nebula = buildNebula();
        ctx.drawImage(nebula, 0, 0);

        // Stars
        for (const s of stars) {
          const op = Math.max(0, Math.min(1, s.base + Math.sin(t * s.freq * 60 + s.phase) * s.range));
          if (s.glow) {
            const bloom = ctx.createRadialGradient(s.x, s.y, 0, s.x, s.y, s.r * 6);
            bloom.addColorStop(0,   `rgba(215,228,255,${op * 0.32})`);
            bloom.addColorStop(0.4, `rgba(180,205,255,${op * 0.10})`);
            bloom.addColorStop(1,   'rgba(0,0,0,0)');
            ctx.fillStyle = bloom;
            ctx.beginPath();
            ctx.arc(s.x, s.y, s.r * 6, 0, Math.PI*2);
            ctx.fill();
          }
          ctx.beginPath();
          ctx.arc(s.x, s.y, s.r, 0, Math.PI*2);
          ctx.fillStyle = `rgba(${s.glow ? '218,230,255' : '200,215,255'},${op})`;
          ctx.fill();
        }

        // Shooting stars
        for (let i = shooters.length - 1; i >= 0; i--) {
          const s = shooters[i];
          s.x    += Math.cos(s.angle) * s.spd;
          s.y    += Math.sin(s.angle) * s.spd;
          s.life -= 0.016;
          if (s.life <= 0) { shooters.splice(i, 1); continue; }

          const fade = s.life > 0.85 ? (1 - s.life) / 0.15
                     : s.life < 0.20 ? s.life / 0.20 : 1;
          const tx = s.x - Math.cos(s.angle) * s.len;
          const ty = s.y - Math.sin(s.angle) * s.len;

          const g = ctx.createLinearGradient(tx, ty, s.x, s.y);
          g.addColorStop(0,   'rgba(255,255,255,0)');
          g.addColorStop(0.5, `rgba(200,220,255,${fade * 0.55})`);
          g.addColorStop(1,   `rgba(255,255,255,${fade})`);
          ctx.beginPath();
          ctx.moveTo(tx, ty);
          ctx.lineTo(s.x, s.y);
          ctx.strokeStyle = g;
          ctx.lineWidth   = 1.5;
          ctx.stroke();

          // Glowing head
          const head = ctx.createRadialGradient(s.x, s.y, 0, s.x, s.y, 5);
          head.addColorStop(0, `rgba(255,255,255,${fade})`);
          head.addColorStop(1, 'rgba(255,255,255,0)');
          ctx.fillStyle = head;
          ctx.beginPath();
          ctx.arc(s.x, s.y, 5, 0, Math.PI*2);
          ctx.fill();
        }

        // Spawn new shooting star (avg every ~5s)
        if (Math.random() < 0.003) {
          const angle = (Math.random() * 0.45 + 0.12) * Math.PI;
          shooters.push({
            x: Math.random() * W * 0.65, y: Math.random() * H * 0.40,
            angle, spd: Math.random() * 9 + 7,
            len: Math.random() * 140 + 90, life: 1.0
          });
        }

        requestAnimationFrame(frame);
      }

      frame();
    })();
    </script>
  </body>
</html>

<style is:global>
  :root {
    color-scheme: light dark;
  }

  html {
    font-family: "Onest Variable", system-ui, sans-serif;
    scroll-behavior: smooth;
    overflow-x: hidden;
    width: 100%;
  }

  body {
    background: transparent;
    overflow-x: hidden;
    width: 100%;
  }

  @media (prefers-reduced-motion: reduce) {
    html {
      scroll-behavior: auto;
    }
  }
</style>
